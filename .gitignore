# Ignore archived backend transport stream dumps
/backend/ts_archive/

# Ignore accidental local HLS/FFmpeg dump files in backend root
/backend/test*.ts
/backend/test*.m3u8
/backend/hls_cache/

# AI-assistent
/.claude/

# Beroenden (Mappar med färdig kod som inte ska laddas upp)
node_modules/
backend/node_modules/

# Byggda och kompilerade filer
dist/
backend/dist/
out/

# Flutter/build artifacts (frontend-specific)
/frontend/build/

# ==========================================
# GENERELLA IGNORERINGAR FÖR ATT UNDVIKA FEL
# ==========================================

# Loggfiler (Detta stoppar .log-filer från att blockera uppladdningen)
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Databaser (Ska aldrig laddas upp till GitHub)
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# Miljövariabler (innehåller ofta lösenord/nycklar och ska aldrig upp)
.env
.env.local

# OS-specifika filer (Dolda systemfiler från Windows/Mac)
.DS_Store
Thumbs.db