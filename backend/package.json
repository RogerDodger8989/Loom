{
  "name": "loom-backend",
  "version": "1.0.0",
  "description": "Loom API-driven Headless Media Server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "testTimeout": 15000,
    "transform": {
      "^.+\\.[tj]sx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "module": "commonjs",
            "allowJs": true
          }
        }
      ]
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(uuid)/)"
    ]
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/static": "^6.12.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "adm-zip": "^0.5.17",
    "axios": "^1.16.1",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.0",
    "nodemailer": "^8.0.10",
    "uuid": "^14.0.0",
    "xml2js": "^0.6.2",
    "yt-dlp-wrap": "^2.3.12"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.41",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@types/xml2js": "^0.4.14",
    "jest": "^30.4.2",
    "pino-pretty": "^11.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.2"
  }
}
